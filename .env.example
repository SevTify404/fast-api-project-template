# FastAPI Project Template - Environment Configuration
# Copy this file to .env and adjust the values as needed

# ============================================
# APPLICATION SETTINGS
# ============================================
ENVIRONMENT=LOCAL
SECRET_KEY=change-me
API_PORT=8000
JWT_EXPIRES_MINUTES=3600
ALGORITHM=HS256
START_PERIOD=5

# ============================================
# DATABASE SETTINGS (PostgreSQL)
# ============================================
DATABASE_USER=admin
DATABASE_PASSWORD=password
DATABASE_TYPE=postgresql
DATABASE_PILOT=asyncpg
DATABASE_HOST=db:5432
BD_OUTPUT_PORT=5433
DATABASE_NAME=app_db

# ============================================
# REDIS SETTINGS (Cache)
# ============================================
REDIS_CACHE_PORT=6379
REDIS_URL=redis://app_redis:6379/0

# ============================================
# NOTES:
# ============================================
# This configuration is operational and ready to use with the provided docker-compose.yml
# Simply copy this file to .env and run: make start_docker